	"item": [
		{
			"name": "1. Health Checks",
			"description": "Verify the service is alive and the database is connected.",
			"item": [
				{
					"name": "GET /health",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
									"pm.test(\"Body has status=ok\", () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.status).to.eql('ok');",
									"    pm.expect(json.service).to.eql('amrutam-telemedicine');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						}
					}
				},
				{
					"name": "GET /db-check",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
									"pm.test(\"Database connected\", () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.db).to.eql('ok');",
									"    pm.expect(json.result).to.eql(1);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/db-check",
							"host": ["{{base_url}}"],
							"path": ["db-check"]
						}
					}
				},
				{
					"name": "GET /health/full",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
									"pm.test(\"Full health includes database\", () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.database).to.eql('ok');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health/full",
							"host": ["{{base_url}}"],
							"path": ["health", "full"]
