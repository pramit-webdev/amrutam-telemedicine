		{
			"name": "5. Doctor Profile & Slots",
			"description": "Create a doctor profile and set availability slots.",
			"item": [
				{
					"name": "POST /doctors/profile",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"pm.test(\"Has doctor id\", () => pm.expect(json.id).to.be.a('string'));",
									"pm.collectionVariables.set('doctor_id', json.id);",
									"pm.test(\"Specialization matches\", () => pm.expect(json.specialization).to.eql('Endocrinology'));"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{doctor_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"specialization\": \"Endocrinology\",\n    \"license_number\": \"MCI-{{$timestamp}}\",\n    \"years_of_experience\": 15,\n    \"consultation_fee\": 1200.0,\n    \"bio\": \"Experienced endocrinologist with 15 years at Apollo Hospitals, specializing in diabetes management and thyroid disorders.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/doctors/profile",
							"host": ["{{base_url}}"],
							"path": ["doctors", "profile"]
						}
					}
				},
				{
					"name": "GET /doctors/profile — Verify",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"pm.test(\"Same doctor returned\", () => pm.expect(json.id).to.eql(pm.collectionVariables.get('doctor_id')));"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{doctor_token}}" }
						],
						"url": {
							"raw": "{{base_url}}/doctors/profile",
							"host": ["{{base_url}}"],
							"path": ["doctors", "profile"]
						}
					}
				},
				{
					"name": "POST /doctors/slots — Create Slots",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"pm.test(\"Returns array of slots\", () => pm.expect(json).to.be.an('array'));",
									"pm.test(\"Has at least 1 slot\", () => pm.expect(json.length).to.be.gte(1));",
									"pm.collectionVariables.set('slot_id', json[0].id);",
									"pm.test(\"First slot has required fields\", () => {",
									"    pm.expect(json[0]).to.have.property('id');",
									"    pm.expect(json[0]).to.have.property('start_time');",
									"    pm.expect(json[0]).to.have.property('end_time');",
									"    pm.expect(json[0].is_booked).to.eql(false);",
									"});"
								]
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"const tomorrow = new Date();",
									"tomorrow.setDate(tomorrow.getDate() + 1);",
									"const start1 = new Date(tomorrow); start1.setHours(9, 0, 0, 0);",
									"const end1 = new Date(start1); end1.setHours(10, 0, 0, 0);",
									"const start2 = new Date(tomorrow); start2.setHours(11, 0, 0, 0);",
									"const end2 = new Date(start2); end2.setHours(12, 0, 0, 0);",
									"pm.variables.set('slot1_start', start1.toISOString());",
									"pm.variables.set('slot1_end', end1.toISOString());",
									"pm.variables.set('slot2_start', start2.toISOString());",
									"pm.variables.set('slot2_end', end2.toISOString());"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{doctor_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"slots\": [\n        {\n            \"start_time\": \"{{slot1_start}}\",\n            \"end_time\": \"{{slot1_end}}\"\n        },\n        {\n            \"start_time\": \"{{slot2_start}}\",\n            \"end_time\": \"{{slot2_end}}\"\n        }\n    ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/doctors/slots",
							"host": ["{{base_url}}"],
							"path": ["doctors", "slots"]
						}
					}
				}
			]
		},
